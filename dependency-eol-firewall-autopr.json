    {
      "parameters": {
        "jsCode": "const owner = $('Config: owner/repo').item.json.owner;\nconst repo = $('Config: owner/repo').item.json.repo;\nconst dep = $('Assess Registry Facts').item.json.name;\nconst cur = $('Assess Registry Facts').item.json.current_version;\nconst latest = $('Assess Registry Facts').item.json.latest_version;\nconst summary = $('Agent 1 \u2014 Watcher/Triage').item.json.output.summary;\nconst H = { 'User-Agent': 'n8n', 'Accept': 'application/vnd.github+json' };\nconst meta = await this.helpers.httpRequest({ url: `https://api.github.com/repos/${owner}/${repo}`, headers: H, json: true });\nconst branch = meta.default_branch;\nconst tree = await this.helpers.httpRequest({ url: `https://api.github.com/repos/${owner}/${repo}/git/trees/${branch}?recursive=1`, headers: H, json: true });\nconst exts = /\\.(js|jsx|ts|tsx|mjs|cjs|vue|svelte)$/i;\nconst files = (tree.tree || []).filter(t => t.type === 'blob' && exts.test(t.path)).slice(0, 25);\nconst esc = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\nconst re = new RegExp(`(require\\\\(['\"\\`]${esc}['\"\\`]\\\\)|from ['\"\\`]${esc}['\"\\`]|import ['\"\\`]${esc}['\"\\`])`);\nconst affected = [];\nfor (const f of files) {\n  try {\n    const txt = await this.helpers.httpRequest({ url: `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/${f.path}`, headers: { 'User-Agent': 'n8n' } });\n    const s = typeof txt === 'string' ? txt : JSON.stringify(txt);\n    if (re.test(s)) {\n      const lines = s.split('\\n').map(l => l.trim()).filter(l => l.includes(dep)).slice(0, 3);\n      affected.push({ path: f.path, snippets: lines });\n    }\n  } catch (e) {}\n}\nreturn { json: { name: dep, current_version: cur, latest_version: latest, risk_summary: summary, total_hits: affected.length, affected_files: affected } };",
        "mode": "runOnceForEachItem"
      },
