      "parameters": {
        "promptType": "define",
        "text": "=You are a migration engineer. Write a complete GitHub Issue that a developer can act on immediately to eliminate this dependency risk. Include the exact upgrade command, an ordered migration plan tied to the specific files, and a unified-diff patch for the clearest change you can infer. If a change is uncertain, mark it as TODO rather than inventing code.\n\nPackage: {{ $('Find Usage In Repo').item.json.name }} {{ $('Find Usage In Repo').item.json.current_version }} -> {{ $('Find Usage In Repo').item.json.latest_version }}\nRisk: {{ $('Agent 1 \u2014 Watcher/Triage').item.json.output.risk_type }} / {{ $('Agent 1 \u2014 Watcher/Triage').item.json.output.severity }}\nSummary: {{ $('Agent 1 \u2014 Watcher/Triage').item.json.output.summary }}\nUsed symbols: {{ JSON.stringify($json.output.used_symbols) }}\nFiles touched: {{ JSON.stringify($json.output.files_touched) }}\nBreaking calls: {{ JSON.stringify($json.output.breaking_calls) }}\nEffort: {{ $json.output.estimated_effort }}",
