        "jsCode": "const p = $('Prep PR Vars').item.json;\nconst pj = $json;\nconst text = Buffer.from(pj.content, 'base64').toString('utf8');\nconst esc = s => String(s).replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\nconst re = new RegExp('(\"' + esc(p.pkg) + '\"\\\\s*:\\\\s*\")([~^]?)' + esc(p.old_version) + '(\")');\nconst newText = text.replace(re, `$1$2${p.new_version}$3`);\nif (newText === text) throw new Error('version string not found for ' + p.pkg);\nreturn { json: { new_content_b64: Buffer.from(newText).toString('base64'), file_sha: pj.sha } };"
