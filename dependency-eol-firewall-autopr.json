    {
      "parameters": {
        "jsCode": "// Decode the GitHub file payload and flatten dependencies into one item per package.\nconst raw = $input.first().json;\nconst b64 = raw.content || (raw.data && raw.data.content) || '';\nconst text = Buffer.from(b64, 'base64').toString('utf8');\nlet pkg;\ntry { pkg = JSON.parse(text); } catch (e) { throw new Error('package.json is not valid JSON: ' + e.message); }\n\nconst deps = { ...(pkg.dependencies || {}), ...(pkg.devDependencies || {}) };\nconst out = [];\nfor (const [name, range] of Object.entries(deps)) {\n  // Skip local/git/workspace pins we can't check on the registry.\n  if (/^(file:|link:|git|github:|workspace:|https?:)/i.test(range)) continue;\n  out.push({\n    json: {\n      name,\n      current_range: range,\n      current_version: String(range).replace(/^[~^>=<\\s]*/, '').split(' ')[0]\n    }\n  });\n}\nif (!out.length) return [{ json: { _empty: true } }];\nreturn out;"
      },
      "id": "parse-manifest",
      "name": "Parse Manifest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
